{
    "name": "spoome/spoome",
    "description": "Spoome — il professional network dello sport. PHP vanilla MVC.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "friendsofphp/php-cs-fixer": "^3.58"
    },
    "autoload": {
        "psr-4": {
            "Spoome\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Spoome\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
