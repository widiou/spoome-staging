# Spoome v2 — routing (la app vive sotto /beta/).
# La docroot IDEALE è public/. Questo file permette il funzionamento anche quando la
# docroot è la root del progetto (caso attuale su /beta/), instradando tutto al front controller
# e negando l'accesso diretto alle cartelle applicative.

Options -Indexes

# Limita il corpo delle richieste a 10MB: gli upload (avatar/cover ri-codificati) sono piccoli,
# così un corpo enorme viene rifiutato dal webserver PRIMA del buffering PHP (anti-DoS).
LimitRequestBody 10485760

<IfModule mod_headers.c>
    # CSP: include frame-src per gli embed video allow-listed (YouTube-nocookie / Vimeo).
    # 'always' → gli header di sicurezza sono applicati anche alle risposte di errore (4xx/5xx).
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Permitted-Cross-Domain-Policies "none"
    Header always set Cross-Origin-Opener-Policy "same-origin"

    # Content-Security-Policy: tutto da 'self' (font e icone ora self-hosted → nessun host esterno).
    # script solo self (nessun inline JS); style inline consentito per gli attributi style=; immagini self + data:.
    # frame-src: solo gli host di embed video allow-listed (iframe sandboxed costruiti da noi).
    # Le immagini di anteprima link passano dall'image-proxy same-origin → coperte da img-src 'self'.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-src 'self' https://www.youtube-nocookie.com https://player.vimeo.com; frame-ancestors 'self'; form-action 'self'; upgrade-insecure-requests"

    # NB HSTS (Strict-Transport-Security): NON impostato qui perché la beta condivide il dominio
    # spoome.it con la PRODUZIONE → una policy HSTS varrebbe per tutto il dominio. Va deciso a livello
    # di dominio insieme alla prod.

    # L'og:image (/og/…) gestisce da sé il Cache-Control (lungo sulle card reali, no-store sui ripieghi):
    # va escluso SIA dal default no-store SIA dalla regola asset-immutable, altrimenti un ripiego (brand-card
    # su errore transitorio / profilo non ancora pubblico) resterebbe cachato 1 anno sull'URL versionato.
    SetEnvIf Request_URI "/og/" SPOOME_OG

    # Default: no-store (protegge le pagine dinamiche/autenticate dalla cache di browser e proxy). Non per /og/.
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0" env=!SPOOME_OG
    Header set Pragma "no-cache" env=!SPOOME_OG
    Header set Expires "0" env=!SPOOME_OG

    # Asset statici versionati (?v=filemtime): far-future immutable. La regola per-estensione
    # sovrascrive il default SOLO per gli asset — l'HTML dinamico resta no-store. Esclude /og/ (vedi sopra).
    SetEnvIf Request_URI "\.(css|js|woff2?|ttf|eot|png|jpe?g|gif|svg|webp|ico|map)$" SPOOME_ASSET
    SetEnvIf Request_URI "/og/" !SPOOME_ASSET
    Header always set Cache-Control "public, max-age=31536000, immutable" env=SPOOME_ASSET
    Header unset Pragma env=SPOOME_ASSET
    Header unset Expires env=SPOOME_ASSET
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Root della app (/beta/) → front controller. Serve una regola esplicita perché la
    # root è una directory esistente e verrebbe esclusa dalla condizione !-d più sotto.
    RewriteRule ^$ public/index.php [L,QSA]

    # Blocca l'accesso diretto alle cartelle applicative sensibili (incluse dev-only tests/).
    RewriteRule ^(?:src|config|database|storage|jobs|vendor|views|tests)(?:/|$) - [F,L]

    # Asset statici e upload: serviti da public/ se non presenti alla root.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(assets/.*|uploads/.*)$ public/$1 [L]

    # Tutto il resto → front controller.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>

# Protezione esplicita: nega tutti i dotfile (.env, .deploy.env, .git*, ...) e file sensibili.
<FilesMatch "(^\.|\.(env|log|sql|bak|old|ini)$|composer\.(json|lock))">
    Require all denied
</FilesMatch>
