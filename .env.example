# === Spoome v2 — template variabili d'ambiente ===
# Copiare in `.env` e compilare coi valori REALI dell'ambiente.
# `.env` NON è tracciato in git. Questo `.example` sì.

# Ambiente: local | staging | production
APP_ENV=staging
APP_DEBUG=true
APP_NAME=Spoome
APP_LOCALE=it
# APP_URL = solo origin (senza path). Il prefisso /beta/ va in BASE_PATH.
APP_URL=https://spoome.it
# Prefisso path pubblico (la app vive sotto /beta/). Gli URL assoluti = APP_URL + BASE_PATH.
BASE_PATH=/beta/

# --- Database (MySQL su SiteGround) ---
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4
# Opzionali, di norma non impostati in prod (porta/socket standard): lasciarli vuoti
# non cambia il DSN generato. Se valorizzato, DB_SOCKET ha priorità su DB_HOST/DB_PORT.
#DB_PORT=
#DB_SOCKET=

# --- Sessione web ---
SESSION_NAME=spoome_session
# SESSION_LIFETIME: scadenza del cookie in minuti (client-side, non attendibile da sola).
SESSION_LIFETIME=120
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax
# Timeout ENFORCED lato server (#5), indipendenti dal cookie:
# SESSION_IDLE_MINUTES: minuti di inattività dopo cui la sessione scade (finestra scorrevole). Default 30.
SESSION_IDLE_MINUTES=30
# SESSION_ABSOLUTE_HOURS: ore dal login dopo cui la sessione scade comunque, anche se attiva. Default 12.
SESSION_ABSOLUTE_HOURS=12

# --- API / token nativi (Bearer) ---
API_PREFIX=/api/v1
JWT_SECRET=
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=2592000

# --- Sicurezza ---
CSRF_TOKEN_NAME=_csrf

# --- Email (verifica account, notifiche) ---
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Spoome

# --- Upload / media ---
MAX_UPLOAD_MB=10

# --- Migrazioni ---
# Runner CLI: `php jobs/migrate.php status|up` (SSH). L'endpoint HTTP /__migrate è stato rimosso
# (superficie inutile). MIGRATION_TOKEN resta: è anche materiale chiave derivato da LinkSigner
# (src/Domain/Links/LinkSigner.php) quando manca un secret esplicito — non rimuoverlo.
MIGRATION_TOKEN=
