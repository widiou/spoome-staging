# === Spoome — template variabili d'ambiente ===
# Copiare in `.env` e compilare con i valori REALI del singolo ambiente.
# Il file `.env` NON va committato (vedi .gitignore). Questo .example sì.

# Ambiente: local | staging | production
APP_ENV=local
APP_DEBUG=true
APP_URL=https://spoome.it
BASE_PATH=/network/

# --- Database applicativo Spoome ---
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# --- Database WordPress (per sync RSS/news) ---
WP_DB_HOST=localhost
WP_DB_NAME=
WP_DB_USER=
WP_DB_PASS=
WP_TABLE_PREFIX=wp_

# --- Google API / Custom Search ---
GOOGLE_API_KEY=
GOOGLE_NEWS_CX=
GOOGLE_SOCIAL_CX=
GOOGLE_VIDEO_CX=

# --- Cache ---
CACHE_TTL_HOURS=12

# --- Sessione ---
SESSION_LIFETIME=120
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

# --- Email ---
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Spoome

# --- Sicurezza ---
CSRF_TOKEN_NAME=_csrf
CSRF_TOKEN_LENGTH=32

# --- Migrazioni (runner web protetto) ---
MIGRATION_TOKEN=
