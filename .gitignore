# Ambiente (segreti) — MAI committare
.env
.env.*
!.env.example

# Credenziali/deploy FTP (segreti locali) — MAI committare
.deploy.env
.deploy.log
.deploy-state.json

# IDE
.idea/

# Runtime
storage/logs/*
storage/cache/*
storage/uploads/*
!storage/**/.gitkeep

# Contenuti caricati dagli utenti (avatar, media, documenti) — non nel repo
public/uploads/*
!public/uploads/.gitkeep
!public/uploads/.htaccess

# OS
.DS_Store
Thumbs.db

# Dipendenze / build
# vendor/ NON è tracciato: la v2 non ha dipendenze runtime Composer (require = solo php).
/vendor
node_modules/

# Cache tool
__pycache__/
*.pyc
.phpunit.result.cache
.php-cs-fixer.cache
